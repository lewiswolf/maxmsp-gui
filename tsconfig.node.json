{
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
		"composite": true,
		"module": "ESNext",
		"moduleDetection": "force",
		"moduleResolution": "bundler",
		"skipLibCheck": true,
		"strict": true,
		"target": "ESNext",
		"types": ["node"],
		"verbatimModuleSyntax": true
	},
	"include": ["vite.config.ts"]
}

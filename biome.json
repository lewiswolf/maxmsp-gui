{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"files": {
		"includes": [
			"**/*.css",
			"**/*.html",
			"**/*.js",
			"**/*.json",
			"**/*.jsx",
			"**/*.ts",
			"**/*.d.ts",
			"**/*.tsx",
			"!**/node_modules",
			"!**/dist",
			"!**/unused"
		]
